# cs2-lab — variáveis de ambiente (copie para `.env` e preencha)
#
#   cp .env.example .env
#
# O backend lê este arquivo a partir da RAIZ do projeto (app/core/config.py),
# independentemente do diretório de onde o uvicorn é iniciado.

# --- PostgreSQL (metadados) ---------------------------------------------------
# Formato: postgresql+psycopg://USUARIO:SENHA@HOST:PORTA/BANCO
#
# Os valores abaixo batem com o docker-compose (serviço `postgres`):
#   usuário=cs2  senha=cs2  banco=cs2_lab
# A porta no HOST é 5544 (o container publica 5544:5432, pois 5432/5433 costumam
# estar ocupadas por um PostgreSQL local). Ajuste se o seu setup for diferente.
#
# Observação: a suíte de testes cria/usa automaticamente um banco `cs2_lab_test`
# no mesmo servidor — não é preciso configurá-lo aqui.
DATABASE_URL=postgresql+psycopg://cs2:cs2@localhost:5544/cs2_lab

REDIS_URL=redis://localhost:6379/0

# URL pública da API embutida no build do frontend Docker.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Aplicação (opcional) -----------------------------------------------------
API_TITLE=cs2-lab API
LOG_LEVEL=INFO
